# occams-agent — runtime config
# Copy to .env and fill in real values. .env is gitignored.

# --- Paths (usually leave as default) ---

# Where the shared vault lives. Default: repo root /vault.
VAULT_DIR=./vault

# Where the runtime looks for <slug>-agent/ profile dirs. Default: repo root.
PROFILES_DIR=.

# users.json mapping (sender phone / Slack id → identity). Gitignored.
USERS_FILE=./users.json

# --- Defaults ---

# Which CLI runs an agent turn when no /claude or /codex override is set.
DEFAULT_AGENT=claude

# Profile to use when a chat has no binding yet. The runtime falls back to the
# profile with `default: true` in its frontmatter if this is unset.
DEFAULT_PROFILE=admin

# Default timezone for scheduled jobs. Use IANA names so daylight saving time
# is handled correctly. America/New_York = US Eastern time.
DEFAULT_TIMEZONE=America/New_York

# Claude permission mode. bypassPermissions = no prompts (required for unattended).
# Tool access is still bounded by cwd + --add-dir.
CLAUDE_PERMISSION_MODE=bypassPermissions

# Codex sandbox + approvals.
CODEX_SANDBOX=workspace-write
CODEX_BYPASS_APPROVALS=true

# --- Channels ---

# WhatsApp via Baileys. Auth session stored in occams-agent-runtime/auth/ on first QR pair.
ENABLE_WHATSAPP=true

# Slack via Bolt Socket Mode. Required scopes: chat:write, app_mentions:read, im:history, im:read.
# Subscribe to: app_mention, message.im.
ENABLE_SLACK=false
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_SIGNING_SECRET=

# --- Transcription (voice notes) ---

# Groq Whisper API. Required for transcribing audio messages in Slack/WhatsApp.
# Free tier: ~25 hours of audio/day. Get a key at console.groq.com.
# Per Groq's Services Agreement, customer audio is NOT used for training.
GROQ_API_KEY=
# Default model is fine; override to "whisper-large-v3" (slower, slightly better) if needed.
GROQ_STT_MODEL=whisper-large-v3-turbo
